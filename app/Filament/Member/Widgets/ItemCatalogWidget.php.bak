<?php

namespace App\Filament\Member\Widgets;

use App\Models\Item;
use Filament\Widgets\Widget;
use Livewire\Attributes\Url;

class ItemCatalogWidget extends Widget
{
    protected static string $view = 'filament.member.widgets.item-catalog';
    
    protected static bool $isLazy = false;
    
    protected int|string|array $columnSpan = 'full';
    
    // Ganti nama dari $sort menjadi $sortBy atau $catalogSort
    #[Url]
    public string $catalogSort = 'newest';
    
    #[Url]
    public string $search = '';
    
    #[Url]
    public ?string $categoryFilter = null;
    
    #[Url]
    public string $viewLayout = 'grid';
    
    public function getItems()
    {
        $query = Item::query();
        
        // Search
        if ($this->search) {
            $query->where(function ($q) {
                $q->where('name', 'like', "%{$this->search}%")
                  ->orWhere('description', 'like', "%{$this->search}%");
            });
        }
        
        // Category filter
        if ($this->categoryFilter) {
            $query->where('category_id', $this->categoryFilter);
        }
        
        // Sorting - menggunakan $catalogSort bukan $sort
        match ($this->catalogSort) {
            'newest' => $query->latest(),
            'oldest' => $query->oldest(),
            'price_low' => $query->orderBy('price', 'asc'),
            'price_high' => $query->orderBy('price', 'desc'),
            'name_asc' => $query->orderBy('name', 'asc'),
            'name_desc' => $query->orderBy('name', 'desc'),
            default => $query->latest(),
        };
        
        return $query->paginate(12);
    }
    
    public static function getSort(): int
    {
        return parent::$sort ?? 0;
    }
}